# Copy to .env and fill in. Used by `config/index.js` (do not commit .env).
PORT=3000
PUBLIC_BASE_URL=https://bot.example.com

DISCORD_BOT_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_CALLBACK_URL=https://bot.example.com/auth/discord/callback
DISCORD_GUILD_ID=
REQUIRED_ROLE=
OWNER_ID=
PREFIX=!
APPLICATION_ID=

SESSION_SECRET=
SESSION_EXPIRES=7

# Optional: mirror logger error/crash to a Discord webhook in a separate
# admin-only server. Off by default; leave LOG_WEBHOOK_URL blank to disable.
# Known env-secret values are auto-redacted from outgoing messages.
LOG_WEBHOOK_URL=
LOG_WEBHOOK_LEVEL=error
LOG_WEBHOOK_USERNAME=f95bot logs

# MySQL: use localhost for a DB on the host. In Docker Compose, use the DB *container* hostname
# f95bot-mysql (see container_name in docker-compose), not the service name "mysql" — on shared
# networks (e.g. Traefik) "mysql" can resolve to another stack's MySQL and look "empty" or wrong.
MYSQL_HOST=f95bot-mysql
MYSQL_PORT=3306
MYSQL_USER=f95bot
MYSQL_PASS=
MYSQL_DB=f95bot
MYSQL_ROOT_PASSWORD=root
MYSQL_RUN_MIGRATIONS=false

REDIS_URL=redis://127.0.0.1:6379
REDIS_PORT=6379

# Roles (Snowflake strings)
DISCORD_STAFF_ROLE_ID=
ROLE_STAFF=
ROLE_MOD=
ROLE_UPLOADER=
ROLE_USER=
ROLE_RETIRED=
ROLE_RESPECTED=
ROLE_TRIALMOD=

# Features
WARNING_SYSTEM_ENABLED=true
IMAGE_ARCHIVE_ENABLED=true
IMAGE_ARCHIVE_UPLOAD_TOKEN=

# Custom command image rehost (ShareX-compatible uploader; web panel only)
IMAGE_REHOST_ENABLED=false
IMAGE_REHOST_UPLOAD_URL=https://overlord.lordainz.xyz/upload
IMAGE_REHOST_UPLOAD_KEY=
IMAGE_REHOST_FILE_FIELD=file
IMAGE_REHOST_URL_JSON_PATH=file.url
IMAGE_REHOST_SKIP_HOSTS=overlord.lordainz.xyz
IMAGE_REHOST_CONCURRENCY=3
IMAGE_REHOST_MAX_BYTES=26214400

# Starboard local archive (survives Discord/server loss). Docker bind-mounts ./starboard-archive.
STARBOARD_ARCHIVE_ENABLED=true
STARBOARD_ARCHIVE_DIR=./starboard-archive
CHANNEL_STATS_ENABLED=false
CORS_ENABLED=false

# Optional: daily sync of phish.gg into the link/invite blacklists (off by default)
PHISH_GG_DAILY_SYNC=false
PHISH_GG_DAILY_SYNC_MS=86400000

# Template (Nunjucks / web)
TEMPLATE_WATCH=false
TEMPLATE_NO_CACHE=false
TEMPLATE_UNDEFINED=true

# APIs (optional integrations; leave blank to disable the dependent command/feature)
CURRENCY_API_KEY=
YOUTUBE_API_KEY=
# imgapi.zonies.xyz — SFW/furry/NSFW reaction images (/furry, migrated fun commands)
IMG_API_KEY=
# Gelbooru (used by /femboy); defaults to anonymous access if blank
FEMBOY_API_KEY=
FEMBOY_USER_ID=
# The Cat API (used by !cat); works without a key but a free key unlocks the full image library
THE_CAT_API_KEY=
# zurl.zonies.xyz — shortens thread / ticket / profile URLs in /attention (optional)
ZONIE_API_KEY=

# Docker: compose overrides MYSQL_HOST=f95bot-mysql and REDIS_URL=redis://redis:6379. Web and bot
# must use f95bot-mysql so they hit this project’s MySQL, not a different container named mysql.
