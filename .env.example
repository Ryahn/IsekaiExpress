# Copy to .env and fill in. Used by `config/index.js` (do not commit .env).
PORT=3000
PUBLIC_BASE_URL=https://bot.example.com
CARD_PUBLIC_URL=https://bot.example.com/public/cards

DISCORD_BOT_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_CALLBACK_URL=https://bot.example.com/auth/discord/callback
DISCORD_GUILD_ID=
REQUIRED_ROLE=
OWNER_ID=
PREFIX=!
APPLICATION_ID=

SESSION_SECRET=
SESSION_EXPIRES=7

MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=f95bot
MYSQL_PASS=
MYSQL_DB=f95bot
MYSQL_ROOT_PASSWORD=root
MYSQL_RUN_MIGRATIONS=false

REDIS_URL=redis://127.0.0.1:6379
REDIS_PORT=6379

# Roles (Snowflake strings)
DISCORD_STAFF_ROLE_ID=
ROLE_STAFF=
ROLE_MOD=
ROLE_UPLOADER=
ROLE_USER=

# Features
WARNING_SYSTEM_ENABLED=true
IMAGE_ARCHIVE_ENABLED=true
CHANNEL_STATS_ENABLED=false
CORS_ENABLED=false
UPLOAD_TOKEN=

# Template (Nunjucks / web)
TEMPLATE_WATCH=false
TEMPLATE_NO_CACHE=false
TEMPLATE_UNDEFINED=true

# APIs
CURRENCY_API_KEY=
YOUTUBE_API_KEY=
API_KEY=anonymous
USER_ID=9455

# /cards list command labels (optional emoji / text)
EMOJI_TYPE=
EMOJI_LEVEL=
EMOJI_POWER=
EMOJI_CLASS=
EMOJI_STAR=

# Docker: set MYSQL_HOST=mysql and REDIS_URL=redis://redis:6379 in Compose overrides
