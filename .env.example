# Copy to .env and fill in. Used by `config/index.js` (do not commit .env).
PORT=3000
PUBLIC_BASE_URL=https://bot.example.com
CARD_PUBLIC_URL=https://bot.example.com/public/cards
# Batch `card_data.tcg_region` (Home Turf): leave unset = no tag; 1-6 = all templates same; random = per card, random valid region for that element (see tcgPveConfig elementPoolForEncounter)
TCG_CATALOG_DEFAULT_REGION=

DISCORD_BOT_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_CALLBACK_URL=https://bot.example.com/auth/discord/callback
DISCORD_GUILD_ID=
REQUIRED_ROLE=
OWNER_ID=
PREFIX=!
APPLICATION_ID=

SESSION_SECRET=
SESSION_EXPIRES=7

# MySQL: use localhost for a DB on the host. In Docker Compose, use the DB *container* hostname
# f95bot-mysql (see container_name in docker-compose), not the service name "mysql" — on shared
# networks (e.g. Traefik) "mysql" can resolve to another stack's MySQL and look "empty" or wrong.
MYSQL_HOST=f95bot-mysql
MYSQL_PORT=3306
MYSQL_USER=f95bot
MYSQL_PASS=
MYSQL_DB=f95bot
MYSQL_ROOT_PASSWORD=root
MYSQL_RUN_MIGRATIONS=false

REDIS_URL=f95bot-redis://127.0.0.1:6379
REDIS_PORT=6379

# Roles (Snowflake strings)
DISCORD_STAFF_ROLE_ID=
ROLE_STAFF=
ROLE_MOD=
ROLE_UPLOADER=
ROLE_USER=
ROLE_RETIRED=
ROLE_RESPECTED=
ROLE_TRIALMOD=

# Farm XP → TCG gold: daily conversion cap (UTC+7 day, same as farm login)
FARM_XP_DAILY_CONVERT_CAP=500

# Features
WARNING_SYSTEM_ENABLED=true
IMAGE_ARCHIVE_ENABLED=true
CHANNEL_STATS_ENABLED=false
CORS_ENABLED=false
UPLOAD_TOKEN=

# Template (Nunjucks / web)
TEMPLATE_WATCH=false
TEMPLATE_NO_CACHE=false
TEMPLATE_UNDEFINED=true

# APIs
CURRENCY_API_KEY=
YOUTUBE_API_KEY=
API_KEY=anonymous
USER_ID=9455

# /cards list command labels (optional emoji / text)
EMOJI_TYPE=
EMOJI_LEVEL=
EMOJI_POWER=
EMOJI_CLASS=
EMOJI_STAR=

# Docker: compose overrides MYSQL_HOST=f95bot-mysql and REDIS_URL=redis://redis:6379. Web and bot
# must use f95bot-mysql so they hit this project’s MySQL, not a different container named mysql.
