# Build context: keep small. Large local paths from .gitignore must be listed here too.

# Dependencies
**/node_modules

# VCS
.git
**/.git

# Secrets
.env

# Logs
logs
**/logs
**/*.log
npm-debug.log

# MySQL dump (can be very large; bind/import via scripts, not the image)
f95bot.sql

# Card renders — local dev art (~15GB+); same as .gitignore **/src/bot/media/cards/*
src/bot/media/cards
**/media/cards

# TCG / Discord export JSON (generated locally; matches root + src/web .gitignore)
**/src/bot/tcg/*_data.json
src/web/tcg/*_data.json

# IDEs / tooling caches
.cursor
**/.cursor
.vscode
**/.vscode

# Local artifacts (see root .gitignore)
batch_*.json
slashCommands.json
test.js
.config.js
chatdump
CardSystem.md
**/level_card.png

# Common dev output (if present)
coverage
.nyc_output
dist
build
