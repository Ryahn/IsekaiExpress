# Build context: keep small. Large local paths from .gitignore must be listed here too.

# Dependencies
**/node_modules

# VCS
.git
**/.git

# Secrets
.env

# Logs
logs
**/logs
**/*.log
npm-debug.log

# MySQL dump (can be very large; bind/import via scripts, not the image)
f95bot.sql

# Generated media can be very large and is not served by the app anymore.
src/bot/media/cards
**/media/cards

# IDEs / tooling caches
.cursor
**/.cursor
.vscode
**/.vscode

# Local artifacts (see root .gitignore)
batch_*.json
slashCommands.json
test.js
.config.js
chatdump
**/level_card.png

# Common dev output (if present)
coverage
.nyc_output
dist
build
