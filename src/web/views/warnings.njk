{% extends "layout.njk" %}
{% block css %}
<link href="https://unpkg.com/tabulator-tables@5.4.3/dist/css/tabulator.min.css" rel="stylesheet">
{% endblock %}

{% block content %}

<div class="vs-page-header">
  <h3 class="vs-page-title">User Warnings</h3>
  <p class="vs-page-subtitle">Review and manage warnings issued to server members</p>
</div>

<div class="search-box">
  <input class="form-control search-input" type="search" id="searchInput" placeholder="Search warnings..." aria-label="Search">
</div>

<div id="warningTable"></div>

<!-- Edit Modal -->
<div class="modal fade" id="editModal" tabindex="-1" aria-labelledby="editModalLabel" aria-hidden="true">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="editModalLabel">Edit Warning</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <form id="editForm">
          <div class="form-group">
            <label for="reason">Reason</label>
            <input type="hidden" name="id" id="warn_id" value="">
            <input type="hidden" name="_csrf" id="csrf" value="{{ csrfToken }}">
            <input type="text" class="form-control" id="reason" placeholder="Warning reason">
          </div>
          <div class="form-group">
            <label for="warnUserId">User ID</label>
            <input type="text" class="form-control" id="warnUserId" placeholder="User ID" readonly>
          </div>
          <div class="form-group">
            <label for="warnUsername">Username</label>
            <input type="text" class="form-control" id="warnUsername" placeholder="Username" readonly>
          </div>
        </form>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
        <button type="button" class="btn btn-primary" id="saveChanges">Save Changes</button>
      </div>
    </div>
  </div>
</div>

<!-- View Full Reason Modal -->
<div class="modal fade" id="fullReasonModal" tabindex="-1" aria-labelledby="fullReasonModalLabel" aria-hidden="true">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="fullReasonModalLabel">Warning Reason</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body" id="fullReasonModalBody" style="white-space: pre-wrap; line-height: 1.6;">
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
      </div>
    </div>
  </div>
</div>

<footer class="footer mt-5">
  <div class="row g-0 justify-content-between align-items-center">
    <div class="col-12 col-sm-auto text-center">
      <p>IsekaiExpress Bot &mdash; made for F95Zone by Ryahn</p>
    </div>
    <div class="col-12 col-sm-auto text-center">
      <p>v1.13.0</p>
    </div>
  </div>
</footer>

<!-- Toast -->
<div class="position-fixed top-0 end-0 p-3" style="z-index: 11; margin-top: 70px;">
  <div class="toast" id="myToast" role="alert" aria-live="assertive" aria-atomic="true" data-bs-delay="3000">
    <div class="toast-header">
      <strong class="me-auto">Message</strong>
      <small class="text-muted" id="timestamp"></small>
      <button type="button" class="btn-close" data-bs-dismiss="toast" aria-label="Close"></button>
    </div>
    <div class="toast-body"></div>
  </div>
</div>

{% endblock %}

{% block scripts %}
<script type="text/javascript" src="https://unpkg.com/tabulator-tables@5.4.3/dist/js/tabulator.min.js"></script>

<script>
  document.querySelector('.logout-link').addEventListener('click', function(e) {
    e.preventDefault();
    document.getElementById('logout-form').submit();
  });

  document.addEventListener('DOMContentLoaded', function() {
    var table = new Tabulator('#warningTable', {
      ajaxURL: '/warnings/list',
      ajaxResponse: function(url, params, response) {
        return response.warnings;
      },
      pagination: 'local',
      paginationSize: 10,
      layout: 'fitColumns',
      columns: [
        { title: 'Warn ID', field: 'warn_id' },
        { title: 'Warned UID', field: 'warn_user_id' },
        { title: 'Warned User', field: 'warn_user' },
        { title: 'Warned By UID', field: 'warn_by_id' },
        { title: 'Warned By', field: 'warn_by_user' },
        {
          title: 'Reason',
          field: 'warn_reason',
          hozAlign: 'center',
          formatter: function(cell) {
            return `<button class="btn btn-sm btn-info viewReasonButton" data-reason="${cell.getValue()}">View</button>`;
          },
          cellClick: function(e, cell) {
            if (e.target.classList.contains('viewReasonButton')) {
              $('#fullReasonModalBody').text(cell.getValue());
              $('#fullReasonModal').modal('show');
            }
          }
        },
        { title: 'Created At', field: 'created_at' },
        { title: 'Updated At', field: 'updated_at' },
        {
          title: 'Actions',
          field: 'warn_id',
          hozAlign: 'center',
          formatter: function(cell) {
            {% if allow %}
            return `<button class="btn btn-sm btn-primary editButton" data-id="${cell.getValue()}">Edit</button>
                    <button class="btn btn-sm btn-danger deleteButton" data-id="${cell.getValue()}">Delete</button>`;
            {% else %}
            return '';
            {% endif %}
          },
          cellClick: function(e, cell) {
            var id = cell.getValue();
            var rowData = cell.getRow().getData();

            if (e.target.classList.contains('editButton')) {
              $('#reason').val(rowData.warn_reason);
              $('#warnUserId').val(rowData.warn_user_id);
              $('#warnUsername').val(rowData.warn_user);
              $('#editModalLabel').text(`Edit Warning For: ${rowData.warn_user}`);
              $('#warn_id').val(id);
              $('#editModal').modal('show');
            }

            if (e.target.classList.contains('deleteButton')) {
              if (confirm('Are you sure you want to delete this warning?')) {
                $.ajax({
                  url: `/warnings/delete/${rowData.warn_id}`,
                  method: 'POST',
                  data: { warn_id: rowData.warn_id, _csrf: '{{ csrfToken }}' },
                  success: function() { table.replaceData(); }
                });
              }
            }
          }
        }
      ]
    });

    document.getElementById('saveChanges').addEventListener('click', function() {
      var reason = $('#reason').val();
      var id = $('#warn_id').val();
      var csrf = $('#csrf').val();

      $.ajax({
        url: '/warnings/edit/' + id,
        method: 'POST',
        data: { reason: reason, _csrf: csrf },
        success: function(response) {
          $('#editModal').modal('hide');
          showToast(response.message, 'success');
          table.replaceData();
        }
      });
    });

    document.getElementById('searchInput').addEventListener('input', function(e) {
      var searchValue = e.target.value.toLowerCase();
      table.setFilter(function(data) {
        return ['warn_id', 'warn_user_id', 'warn_user', 'warn_by_id', 'warn_by_user', 'warn_reason', 'created_at', 'updated_at']
          .some(function(field) {
            return typeof data[field] === 'string' && data[field].toLowerCase().includes(searchValue);
          });
      });
    });
  });

  function showToast(message, type) {
    var toastEl = document.getElementById('myToast');
    var toastBody = toastEl.querySelector('.toast-body');
    toastEl.classList.remove('text-bg-success', 'text-bg-danger');
    toastEl.classList.add(type === 'success' ? 'text-bg-success' : 'text-bg-danger');
    toastBody.textContent = message;
    new bootstrap.Toast(toastEl).show();
  }
</script>
{% endblock %}
