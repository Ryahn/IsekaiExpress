{% extends "layout.njk" %}
{% block css %}
<link href="https://unpkg.com/tabulator-tables@5.4.3/dist/css/tabulator.min.css" rel="stylesheet">
{% endblock %}

{% block content %}

<div x-data="warningsPanel({ canEdit: {% if allow %}true{% else %}false{% endif %}, csrfToken: '{{ csrfToken }}' })" x-init="init()">
<div class="vs-page-header">
  <h3 class="vs-page-title">User Warnings</h3>
  <p class="vs-page-subtitle">Review and manage warnings issued to server members</p>
</div>

<div class="search-box">
  <input class="form-control search-input" type="search" x-model="search" placeholder="Search warnings..." aria-label="Search">
</div>

<p class="text-body-secondary small" x-show="isLoading" x-cloak>Refreshing warnings...</p>
<div id="warningTable"></div>

<!-- Edit Modal -->
<div class="modal fade" id="editModal" tabindex="-1" aria-labelledby="editModalLabel" aria-hidden="true">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="editModalLabel">Edit Warning</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <form id="editForm">
          <div class="form-group">
            <label for="reason">Reason</label>
            <input type="hidden" name="id" x-model="edit.id" value="">
            <input type="hidden" name="_csrf" id="csrf" value="{{ csrfToken }}">
            <input type="text" class="form-control" id="reason" x-model="edit.reason" placeholder="Warning reason">
          </div>
          <div class="form-group">
            <label for="warnUserId">User ID</label>
            <input type="text" class="form-control" id="warnUserId" x-model="edit.userId" placeholder="User ID" readonly>
          </div>
          <div class="form-group">
            <label for="warnUsername">Username</label>
            <input type="text" class="form-control" id="warnUsername" x-model="edit.username" placeholder="Username" readonly>
          </div>
        </form>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
        <button type="button" class="btn btn-primary" @click="saveEdit">Save Changes</button>
      </div>
    </div>
  </div>
</div>

<!-- View Full Reason Modal -->
<div class="modal fade" id="fullReasonModal" tabindex="-1" aria-labelledby="fullReasonModalLabel" aria-hidden="true">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="fullReasonModalLabel">Warning Reason</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body" id="fullReasonModalBody" style="white-space: pre-wrap; line-height: 1.6;" x-text="reason">
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
      </div>
    </div>
  </div>
</div>

<footer class="footer mt-5">
  <div class="row g-0 justify-content-between align-items-center">
    <div class="col-12 col-sm-auto text-center">
      <p>IsekaiExpress Bot &mdash; made for F95Zone by Ryahn</p>
    </div>
    <div class="col-12 col-sm-auto text-center">
      <p>v1.13.0</p>
    </div>
  </div>
</footer>

</div>

{% endblock %}

{% block scripts %}
<script type="text/javascript" src="https://unpkg.com/tabulator-tables@5.4.3/dist/js/tabulator.min.js"></script>
{% endblock %}
