{% extends "layout.njk" %}

{% block content %}

<script type="application/json" id="scamScanRulesState">{{ alpineStateJson | safe }}</script>
<div x-data="scamScanRulesPanel(JSON.parse(document.getElementById('scamScanRulesState').textContent))" x-init="init()">
<div class="vs-page-header">
  <h3 class="vs-page-title">Image Scam Scan Rules</h3>
  <p class="vs-page-subtitle">Manage OCR keyword rules used by the image scam scanner</p>
</div>

<div class="row g-4">
  <div class="col-12 col-xl-7">
    <div class="card">
      <div class="card-header">
        <h5 class="mb-0">Keyword Rules</h5>
      </div>
      <div class="card-body">
        <p class="text-body-secondary">
          One rule per line. Blank lines are ignored. Lines starting with <code>#</code> are comments.
          Use <code>keyword:example phrase</code> for text keywords.
          Use <code>domain:example.com</code> for domains.
          Bare lines are treated as keyword rules. Regex is not enabled yet.
          Avoid very short keywords because they can match unrelated OCR text.
        </p>
        <form method="post" action="/scam-scan-rules/save" @submit.prevent="saveRules">
          <input type="hidden" name="_csrf" value="{{ csrfToken }}">
          <div class="mb-3">
            <label class="form-label" for="rules">Enabled keyword rules (<span x-text="ruleCount"></span>)</label>
            <textarea class="form-control" id="rules" name="rules" rows="18" spellcheck="false" x-model="rules"></textarea>
          </div>
          <button class="btn btn-primary" type="submit" :disabled="isSaving">
            <span x-text="isSaving ? 'Saving...' : 'Save Rules'"></span>
          </button>
        </form>
      </div>
    </div>
  </div>

  <div class="col-12 col-xl-5">
    <div class="card">
      <div class="card-header">
        <h5 class="mb-0">Test OCR Text</h5>
      </div>
      <div class="card-body">
        <p class="text-body-secondary">
          Paste sample OCR text to preview keyword matches. Test text is not saved.
        </p>
        <form method="post" action="/scam-scan-rules/test" @submit.prevent="testRules">
          <input type="hidden" name="_csrf" value="{{ csrfToken }}">
          <div class="mb-3">
            <label class="form-label" for="test_text">Sample OCR text</label>
            <textarea class="form-control" id="test_text" name="test_text" rows="8" x-model="testText"></textarea>
          </div>
          <button class="btn btn-secondary" type="submit" :disabled="isTesting">
            <span x-text="isTesting ? 'Testing...' : 'Test Rules'"></span>
          </button>
        </form>

        <template x-if="testMatches">
          <div>
            <hr>
            <h6>Matches</h6>
            <template x-if="testMatches.matches && testMatches.matches.length">
              <ul>
                <template x-for="match in testMatches.matches" :key="match.type + ':' + match.pattern">
                  <li><code x-text="match.pattern"></code> <span class="text-body-secondary">(<span x-text="match.type"></span>)</span></li>
                </template>
              </ul>
            </template>
            <p class="text-body-secondary mb-0" x-show="!testMatches.matches || !testMatches.matches.length">No rules matched the sample text.</p>
          </div>
        </template>
      </div>
    </div>
  </div>
</div>

<footer class="footer mt-5">
  <div class="row g-0 justify-content-between align-items-center">
    <div class="col-12 col-sm-auto text-center">
      <p>IsekaiExpress Bot &mdash; made for F95Zone by Ryahn</p>
    </div>
    <div class="col-12 col-sm-auto text-center">
      <p>v1.13.0</p>
    </div>
  </div>
</footer>

</div>

{% endblock %}
