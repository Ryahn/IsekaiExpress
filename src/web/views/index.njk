{% extends "layout.njk" %}

{% block content %}

<!-- Welcome Banner -->
<div class="vs-welcome">
  <div class="row align-items-center">
    <div class="col">
      <p class="vs-welcome-title">Welcome back, <span>{{ username }}</span></p>
      <p class="vs-welcome-subtitle">IsekaiExpress Bot Control Panel &mdash; manage commands, moderation, and more.</p>
      <span class="vs-welcome-badge">
        <span data-feather="activity" style="width:11px;height:11px;"></span>
        v1.13.0
      </span>
    </div>
    <div class="col-auto d-none d-md-block">
      <div class="avatar" style="width:64px;height:64px;">
        <img class="rounded-circle" src="{{ avatarUrl }}" alt="{{ username }}" style="width:100%;height:100%;object-fit:cover;" />
      </div>
    </div>
  </div>
</div>

<!-- Feature Cards -->
<p class="vs-section-title">Quick Access</p>

{% if showModCommandDocs and systemHealth %}
<div class="card mb-4" x-data="systemHealthCard({ initial: {{ systemHealthJson | safe }} })" x-init="init()">
  <div class="card-body">
    <div class="d-flex flex-wrap align-items-center justify-content-between gap-2 mb-3">
      <h5 class="card-title mb-0">System status</h5>
      <button type="button" class="btn btn-sm btn-outline-secondary" @click="refresh()" :disabled="isLoading">
        <span x-show="!isLoading">Refresh</span>
        <span x-show="isLoading">Refreshing...</span>
      </button>
    </div>
    <div class="row g-3">
      <div class="col-md-3">
        <span class="badge" :class="health.imgApi.configured ? 'text-bg-success' : 'text-bg-warning'">Img API</span>
        <div class="small text-body-secondary" x-text="health.imgApi.configured ? 'Configured' : 'Not configured'"></div>
      </div>
      <div class="col-md-3">
        <span class="badge" :class="health.mysql.ok ? 'text-bg-success' : 'text-bg-danger'">MySQL</span>
        <div class="small text-body-secondary" x-text="health.mysql.ok ? 'Connected' : 'Unreachable'"></div>
      </div>
      <div class="col-md-3">
        <span class="badge" :class="health.starboardArchive.enabled ? 'text-bg-info' : 'text-bg-secondary'">Starboard archive</span>
        <div class="small text-body-secondary" x-text="starboardLabel()"></div>
      </div>
      <div class="col-md-3">
        <span class="badge" :class="phishBadgeClass()">phish.gg sync</span>
        <div class="small text-body-secondary" x-text="phishLabel()"></div>
      </div>
    </div>
  </div>
</div>
{% endif %}

<div class="row g-4">
  <div class="col-md-4">
    <a href="/commands" class="vs-card">
      <div class="vs-card-icon">
        <span data-feather="terminal"></span>
      </div>
      <h5>Custom Commands</h5>
      <p>Create, edit, and delete custom bot commands. Control what responses the bot gives to specific triggers.</p>
      <span class="vs-card-link">Manage &rarr;</span>
    </a>
  </div>

  <div class="col-md-4">
    <a href="/commands/slashes" class="vs-card">
      <div class="vs-card-icon">
        <span data-feather="zap"></span>
      </div>
      <h5>Slash Commands</h5>
      <p>Browse all registered slash commands available in the server. View names and descriptions at a glance.</p>
      <span class="vs-card-link">Browse &rarr;</span>
    </a>
  </div>

  <div class="col-md-4">
    <a href="/commands/chat" class="vs-card">
      <div class="vs-card-icon">
        <span data-feather="message-square"></span>
      </div>
      <h5>Chat Commands</h5>
      <p>Browse built-in prefix commands such as <code>!cat</code> and <code>!meme</code>. View aliases and categories.</p>
      <span class="vs-card-link">Browse &rarr;</span>
    </a>
  </div>

  {% if showModCommandDocs %}
  <div class="col-md-4">
    <a href="/warnings" class="vs-card">
      <div class="vs-card-icon">
        <span data-feather="alert-triangle"></span>
      </div>
      <h5>Warnings</h5>
      <p>Review and manage user warnings issued by moderators. Edit reasons or remove warnings as needed.</p>
      <span class="vs-card-link">Review &rarr;</span>
    </a>
  </div>
  {% endif %}

  {% if showModCommandDocs %}
  <div class="col-md-4">
    <a href="/server-stats" class="vs-card">
      <div class="vs-card-icon">
        <span data-feather="bar-chart-2"></span>
      </div>
      <h5>Server stats</h5>
      <p>Channel message activity and XP leaderboard from the bot database.</p>
      <span class="vs-card-link">View stats &rarr;</span>
    </a>
  </div>
  <div class="col-md-4">
    <a href="/modhelp" class="vs-card">
      <div class="vs-card-icon">
        <span data-feather="book-open"></span>
      </div>
      <h5>Mod commands</h5>
      <p>Full reference for the <code>/mod</code> slash tree: subcommands, options, and staff-gated behavior.</p>
      <span class="vs-card-link">Open docs &rarr;</span>
    </a>
  </div>
  {% endif %}
</div>

<!-- Footer -->
<footer class="footer mt-5">
  <div class="row g-0 justify-content-between align-items-center">
    <div class="col-12 col-sm-auto text-center">
      <p>IsekaiExpress Bot &mdash; made for F95Zone by Ryahn</p>
    </div>
    <div class="col-12 col-sm-auto text-center">
      <p>v1.13.0</p>
    </div>
  </div>
</footer>

{% endblock %}
