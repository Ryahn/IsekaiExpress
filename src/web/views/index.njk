{% extends "layout.njk" %}

{% block content %}

<!-- Welcome Banner -->
<div class="vs-welcome">
  <div class="row align-items-center">
    <div class="col">
      <p class="vs-welcome-title">Welcome back, <span>{{ username }}</span></p>
      <p class="vs-welcome-subtitle">IsekaiExpress Bot Control Panel &mdash; manage commands, moderation, and more.</p>
      <span class="vs-welcome-badge">
        <span data-feather="activity" style="width:11px;height:11px;"></span>
        v1.13.0
      </span>
    </div>
    <div class="col-auto d-none d-md-block">
      <div class="avatar" style="width:64px;height:64px;">
        <img class="rounded-circle" src="{{ avatarUrl }}" alt="{{ username }}" style="width:100%;height:100%;object-fit:cover;" />
      </div>
    </div>
  </div>
</div>

<!-- Feature Cards -->
<p class="vs-section-title">Quick Access</p>

<div class="row g-4">
  <div class="col-md-4">
    <a href="/commands" class="vs-card">
      <div class="vs-card-icon">
        <span data-feather="terminal"></span>
      </div>
      <h5>Custom Commands</h5>
      <p>Create, edit, and delete custom bot commands. Control what responses the bot gives to specific triggers.</p>
      <span class="vs-card-link">Manage &rarr;</span>
    </a>
  </div>

  <div class="col-md-4">
    <a href="/commands/slashes" class="vs-card">
      <div class="vs-card-icon">
        <span data-feather="zap"></span>
      </div>
      <h5>Slash Commands</h5>
      <p>Browse all registered slash commands available in the server. View names and descriptions at a glance.</p>
      <span class="vs-card-link">Browse &rarr;</span>
    </a>
  </div>

  <div class="col-md-4">
    <a href="/warnings" class="vs-card">
      <div class="vs-card-icon">
        <span data-feather="alert-triangle"></span>
      </div>
      <h5>Warnings</h5>
      <p>Review and manage user warnings issued by moderators. Edit reasons or remove warnings as needed.</p>
      <span class="vs-card-link">Review &rarr;</span>
    </a>
  </div>

  {% if showModCommandDocs %}
  <div class="col-md-4">
    <a href="/modhelp" class="vs-card">
      <div class="vs-card-icon">
        <span data-feather="book-open"></span>
      </div>
      <h5>Mod commands</h5>
      <p>Full reference for the <code>/mod</code> slash tree: subcommands, options, and staff-gated behavior.</p>
      <span class="vs-card-link">Open docs &rarr;</span>
    </a>
  </div>
  {% endif %}
</div>

<!-- Footer -->
<footer class="footer mt-5">
  <div class="row g-0 justify-content-between align-items-center">
    <div class="col-12 col-sm-auto text-center">
      <p>IsekaiExpress Bot &mdash; made for F95Zone by Ryahn</p>
    </div>
    <div class="col-12 col-sm-auto text-center">
      <p>v1.13.0</p>
    </div>
  </div>
</footer>

<!-- Toast -->
<div class="position-fixed top-0 end-0 p-3" style="z-index: 11; margin-top: 70px;">
  <div class="toast" id="myToast" role="alert" aria-live="assertive" aria-atomic="true" data-bs-delay="3000">
    <div class="toast-header">
      <strong class="me-auto">Message</strong>
      <small class="text-muted" id="timestamp"></small>
      <button type="button" class="btn-close" data-bs-dismiss="toast" aria-label="Close"></button>
    </div>
    <div class="toast-body"></div>
  </div>
</div>

{% endblock %}

{% block scripts %}
<script>
  document.querySelector('.logout-link').addEventListener('click', function(e) {
    e.preventDefault();
    document.getElementById('logout-form').submit();
  });
</script>
{% endblock %}
