<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Character Voting — IsekaiExpress</title>

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,400&display=swap" rel="stylesheet" />

  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          fontFamily: {
            display: ['Syne', 'sans-serif'],
            body: ['DM Sans', 'sans-serif'],
          },
          colors: {
            obsidian: {
              950: '#06070f',
              900: '#0b0d1a',
              800: '#10142b',
              700: '#171c38',
              600: '#1e2444',
            },
            discord: '#5865F2',
          },
        },
      },
    };
  </script>

  <style>
    body { font-family: 'DM Sans', sans-serif; }
    h1, h2, h3, .font-display { font-family: 'Syne', sans-serif; }

    .card-image { aspect-ratio: 3/4; object-fit: cover; }

    .vote-btn { transition: all 0.15s ease; }
    .vote-btn:hover:not(:disabled) { transform: scale(1.08); }
    .vote-btn:active:not(:disabled) { transform: scale(0.95); }
    .vote-btn:disabled { opacity: 0.4; cursor: not-allowed; }

    .drop-zone.dragging {
      border-color: #818cf8;
      background-color: rgba(99, 102, 241, 0.08);
    }

    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(16px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    .card-enter { animation: fadeUp 0.4s ease forwards; }

    .submit-panel { transition: max-height 0.35s ease, opacity 0.25s ease; overflow: hidden; }
    .submit-panel.collapsed { max-height: 0; opacity: 0; }
    .submit-panel.expanded  { max-height: 650px; opacity: 1; }

    .season-panel { transition: max-height 0.3s ease, opacity 0.2s ease; overflow: hidden; }
    .season-panel.collapsed { max-height: 0; opacity: 0; }
    .season-panel.expanded  { max-height: 120px; opacity: 1; }

    ::-webkit-scrollbar { width: 6px; }
    ::-webkit-scrollbar-track { background: #0b0d1a; }
    ::-webkit-scrollbar-thumb { background: #2e3352; border-radius: 3px; }
  </style>
</head>

<body class="bg-obsidian-950 text-slate-200 min-h-screen">

  <!-- ── Header ──────────────────────────────────────────────────── -->
  <header class="border-b border-white/5 bg-obsidian-900/80 backdrop-blur-md sticky top-0 z-50">
    <div class="max-w-6xl mx-auto px-4 h-16 flex items-center justify-between">
      <a href="/char_voting" class="flex items-center gap-3 group">
        <div class="w-8 h-8 rounded-lg bg-indigo-600 flex items-center justify-center text-white font-display font-bold text-sm group-hover:bg-indigo-500 transition-colors">CV</div>
        <span class="font-display font-700 text-lg tracking-tight text-white">Char<span class="text-indigo-400">Vote</span></span>
      </a>

      <!-- Season status pill -->
      {% if season %}
        {% if seasonActive %}
          <span class="hidden sm:flex items-center gap-1.5 text-xs font-semibold text-emerald-400 bg-emerald-400/10 border border-emerald-400/20 rounded-full px-3 py-1">
            <span class="w-1.5 h-1.5 rounded-full bg-emerald-400 animate-pulse"></span>
            {{ season.name }} — Active
          </span>
        {% elif season.status == 'complete' %}
          <span class="hidden sm:flex items-center gap-1.5 text-xs font-semibold text-violet-400 bg-violet-400/10 border border-violet-400/20 rounded-full px-3 py-1">
            <span class="w-1.5 h-1.5 rounded-full bg-violet-400"></span>
            {{ season.name }} — Complete
          </span>
        {% else %}
          <span class="hidden sm:flex items-center gap-1.5 text-xs font-semibold text-slate-500 bg-white/5 border border-white/8 rounded-full px-3 py-1">
            <span class="w-1.5 h-1.5 rounded-full bg-slate-500"></span>
            {{ season.name }} — Closed
          </span>
        {% endif %}
      {% else %}
        <span class="hidden sm:flex items-center gap-1.5 text-xs font-semibold text-slate-600 bg-white/3 border border-white/5 rounded-full px-3 py-1">
          No active season
        </span>
      {% endif %}

      <div class="flex items-center gap-3">
        {% if user %}
          <div class="flex items-center gap-2 bg-obsidian-800 border border-white/8 rounded-full px-3 py-1.5">
            {% if user.avatar %}
              <img src="https://cdn.discordapp.com/avatars/{{ user.id }}/{{ user.avatar }}.webp?size=64"
                alt="{{ user.username }}" class="w-6 h-6 rounded-full" />
            {% else %}
              <div class="w-6 h-6 rounded-full bg-indigo-700 flex items-center justify-center text-xs font-semibold text-white">{{ user.username[0] | upper }}</div>
            {% endif %}
            <span class="text-sm font-medium text-slate-200">{{ user.username }}</span>
          </div>
          <form action="/auth/logout" method="POST" style="display:inline;">
            <input type="hidden" name="_csrf" value="{{ csrfToken }}" />
            <button type="submit" class="text-xs text-slate-500 hover:text-slate-300 transition-colors px-2 py-1 rounded hover:bg-white/5">Sign out</button>
          </form>
        {% else %}
          <a href="/auth/login"
            class="flex items-center gap-2 bg-discord hover:bg-[#4752c4] text-white text-sm font-semibold px-4 py-2 rounded-lg transition-colors shadow-lg shadow-indigo-900/30">
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057.1 18.08.11 18.1.13 18.115a19.9 19.9 0 0 0 5.993 3.03.077.077 0 0 0 .084-.028 14.09 14.09 0 0 0 1.226-1.994.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03z"/></svg>
            Login with Discord
          </a>
        {% endif %}
      </div>
    </div>
  </header>

  <main class="max-w-6xl mx-auto px-4 py-10">

    <!-- ── Hero ────────────────────────────────────────────────────── -->
    <div class="mb-8">
      <h1 class="font-display text-4xl font-800 text-white mb-2 tracking-tight">Character Voting</h1>
      <p class="text-slate-400 text-base max-w-xl">Suggest characters from games &amp; anime you'd love to see added. One submission per season. Vote up the ones you want most.</p>
    </div>

    {% if viewingPastSeason %}
    <div class="mb-8 flex items-center gap-3 bg-indigo-500/10 border border-indigo-500/25 rounded-2xl px-5 py-4">
      <svg class="w-5 h-5 text-indigo-400 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
      <div class="flex-1 min-w-0">
        <p class="text-sm font-semibold text-indigo-300">Viewing a past season</p>
        <p class="text-xs text-slate-500 mt-0.5">You are managing <span class="text-slate-400">{{ season.name }}</span> (staff). This is not the default page most visitors see.</p>
      </div>
      <a href="/char_voting" class="flex-shrink-0 text-xs font-semibold text-indigo-400 hover:text-indigo-300 whitespace-nowrap">Current view →</a>
    </div>
    {% endif %}

    <!-- ── Season closed / no season banner ────────────────────────── -->
    {% if not seasonActive %}
      {% if season %}
        {% if season.status == 'complete' %}
        <div class="mb-8 flex items-center gap-3 bg-violet-400/8 border border-violet-400/20 rounded-2xl px-5 py-4">
          <svg class="w-5 h-5 text-violet-400 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          <div>
            <p class="text-sm font-semibold text-violet-300">{{ season.name }} is finalized</p>
            <p class="text-xs text-slate-500 mt-0.5">Submissions and voting are closed.{% if isAdmin %} Approve nominations below to add them to the permanent blocklist.{% endif %}</p>
          </div>
        </div>
        {% else %}
        <div class="mb-8 flex items-center gap-3 bg-amber-400/8 border border-amber-400/20 rounded-2xl px-5 py-4">
          <svg class="w-5 h-5 text-amber-400 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z"/></svg>
          <div>
            <p class="text-sm font-semibold text-amber-300">{{ season.name }} has ended</p>
            <p class="text-xs text-slate-500 mt-0.5">Submissions and voting are closed. Results are shown below.{% if isAdmin %} Mark the season complete to approve winners for the blocklist, or start a new season after finalizing.{% endif %}</p>
          </div>
        </div>
        {% endif %}
      {% else %}
        <div class="mb-8 flex items-center gap-3 bg-slate-800/50 border border-white/8 rounded-2xl px-5 py-4">
          <svg class="w-5 h-5 text-slate-500 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          <div>
            <p class="text-sm font-semibold text-slate-300">No season active</p>
            <p class="text-xs text-slate-500 mt-0.5">Voting hasn't started yet.{% if isAdmin %} Use the admin panel below to start the first season.{% endif %}</p>
          </div>
        </div>
      {% endif %}
    {% endif %}

    <!-- ── Admin Panel ──────────────────────────────────────────────── -->
    {% if isAdmin %}
    <div class="mb-8 bg-obsidian-800 border border-indigo-500/20 rounded-2xl p-5">
      <div class="flex items-center justify-between">
        <div class="flex items-center gap-2">
          <svg class="w-4 h-4 text-indigo-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"/></svg>
          <span class="text-sm font-semibold font-display text-indigo-300">Staff Controls</span>
        </div>
        <div class="flex flex-wrap items-center gap-2 justify-end">
          <a href="/char_voting/admin/seasons"
            class="flex items-center gap-1.5 text-xs font-semibold text-slate-400 bg-white/5 border border-white/10 hover:bg-white/10 px-3 py-1.5 rounded-lg transition-colors">
            Past seasons
          </a>
          {% if season and not seasonActive and season.status == 'closed' %}
            <button type="button" onclick="markSeasonComplete()"
              class="flex items-center gap-1.5 text-xs font-semibold text-violet-400 bg-violet-400/10 border border-violet-400/20 hover:bg-violet-400/15 px-3 py-1.5 rounded-lg transition-colors">
              Mark season complete
            </button>
          {% endif %}
          {% if seasonActive %}
            <button onclick="closeSeason()"
              class="flex items-center gap-1.5 text-xs font-semibold text-rose-400 bg-rose-400/10 border border-rose-400/20 hover:bg-rose-400/15 px-3 py-1.5 rounded-lg transition-colors">
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
              Close Season
            </button>
          {% endif %}
          <button id="newSeasonToggle" onclick="toggleNewSeason()"
            class="flex items-center gap-1.5 text-xs font-semibold text-emerald-400 bg-emerald-400/10 border border-emerald-400/20 hover:bg-emerald-400/15 px-3 py-1.5 rounded-lg transition-colors">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/></svg>
            New Season
          </button>
        </div>
      </div>

      <!-- New season name input (toggled) -->
      <div id="newSeasonPanel" class="season-panel collapsed">
        <div class="mt-4 flex items-center gap-3">
          <input type="text" id="newSeasonName" placeholder='e.g. "Season 1" or "Summer 2026"' maxlength="100"
            class="flex-1 bg-obsidian-700 border border-white/10 rounded-lg px-4 py-2 text-sm text-white placeholder-slate-500 focus:outline-none focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500/40 transition-colors" />
          <button onclick="startSeason()"
            class="flex-shrink-0 bg-indigo-600 hover:bg-indigo-500 text-white text-sm font-semibold px-4 py-2 rounded-lg transition-colors">
            Start
          </button>
        </div>
        <p id="seasonAdminError" class="hidden text-xs text-rose-400 mt-2"></p>
      </div>
    </div>
    {% endif %}

    <!-- ── Submit Panel ─────────────────────────────────────────────── -->
    {% if user and seasonActive %}
      {% if userSubmitted %}
        <div class="mb-8 flex items-center gap-3 bg-indigo-500/8 border border-indigo-500/20 rounded-2xl px-5 py-4">
          <svg class="w-5 h-5 text-indigo-400 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          <div>
            <p class="text-sm font-semibold text-indigo-300">You've already submitted this season</p>
            <p class="text-xs text-slate-500 mt-0.5">One submission per season. You can still vote on others!</p>
          </div>
        </div>
      {% else %}
        <div class="mb-8">
          <button id="toggleSubmit"
            class="flex items-center gap-2 text-sm font-semibold text-indigo-400 hover:text-indigo-300 transition-colors mb-4 group">
            <svg id="toggleIcon" class="w-5 h-5 transition-transform" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/>
            </svg>
            <span id="toggleLabel">Submit a Character</span>
          </button>

          <div id="submitPanel" class="submit-panel collapsed">
            <div class="bg-obsidian-800 border border-white/8 rounded-2xl p-6">
              <div id="submitError" class="hidden mb-4 text-sm text-rose-400 bg-rose-400/10 border border-rose-400/20 rounded-lg px-4 py-3"></div>
              <form id="submitForm" enctype="multipart/form-data" class="flex flex-col md:flex-row gap-6">
                <!-- Drop zone -->
                <div class="flex-shrink-0 w-full md:w-48">
                  <div id="dropZone"
                    class="drop-zone border-2 border-dashed border-white/15 rounded-xl flex flex-col items-center justify-center cursor-pointer hover:border-indigo-500/50 transition-colors"
                    style="height:192px;">
                    <input type="file" name="image" id="imageInput" accept=".png,.jpg,.jpeg,.webp,.avif" class="hidden" required />
                    <div id="dropPlaceholder" class="flex flex-col items-center gap-2 pointer-events-none select-none">
                      <svg class="w-8 h-8 text-slate-500" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5m-13.5-9L12 3m0 0l4.5 4.5M12 3v13.5"/>
                      </svg>
                      <span class="text-xs text-slate-500 text-center px-2">Drop image here<br/>or click to browse</span>
                      <span class="text-xs text-slate-600">PNG · JPG · WEBP · AVIF</span>
                      <span class="text-xs text-slate-600">900×900 – 1024×1024 px</span>
                    </div>
                    <img id="imagePreview" src="" alt="" class="hidden w-full h-full object-cover rounded-xl" />
                  </div>
                </div>

                <!-- Fields -->
                <div class="flex-1 flex flex-col gap-4">
                  <div>
                    <label class="block text-xs font-semibold text-slate-400 uppercase tracking-wider mb-1.5">Character Name</label>
                    <input type="text" name="char_name" placeholder="e.g. Rem" required
                      class="w-full bg-obsidian-700 border border-white/10 rounded-lg px-4 py-2.5 text-sm text-white placeholder-slate-500 focus:outline-none focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500/40 transition-colors" />
                  </div>
                  <div>
                    <label class="block text-xs font-semibold text-slate-400 uppercase tracking-wider mb-1.5">Game / Anime</label>
                    <input type="text" name="game_name" placeholder="e.g. Re:Zero" required
                      class="w-full bg-obsidian-700 border border-white/10 rounded-lg px-4 py-2.5 text-sm text-white placeholder-slate-500 focus:outline-none focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500/40 transition-colors" />
                  </div>
                  <button type="submit" id="submitBtn"
                    class="self-start mt-auto bg-indigo-600 hover:bg-indigo-500 disabled:opacity-50 disabled:cursor-not-allowed text-white text-sm font-semibold px-6 py-2.5 rounded-lg transition-colors shadow-lg shadow-indigo-900/30">
                    Submit Character
                  </button>
                </div>
              </form>
            </div>
          </div>
        </div>
      {% endif %}
    {% elif user and not seasonActive %}
      {# logged in but no active season — no submit UI needed, banner already shown above #}
    {% else %}
      <div class="mb-8 bg-obsidian-800 border border-white/8 rounded-2xl px-6 py-5 flex items-center justify-between">
        <div>
          <p class="font-display font-semibold text-white text-sm">Want to suggest a character?</p>
          <p class="text-slate-500 text-sm mt-0.5">Login with Discord to submit and vote.</p>
        </div>
        <a href="/auth/login"
          class="flex items-center gap-2 bg-discord hover:bg-[#4752c4] text-white text-sm font-semibold px-4 py-2 rounded-lg transition-colors whitespace-nowrap">
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057.1 18.08.11 18.1.13 18.115a19.9 19.9 0 0 0 5.993 3.03.077.077 0 0 0 .084-.028 14.09 14.09 0 0 0 1.226-1.994.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03z"/></svg>
          Login with Discord
        </a>
      </div>
    {% endif %}

    <!-- ── Character Grid ───────────────────────────────────────────── -->
    <div>
      <div class="flex items-center justify-between mb-6">
        <h2 class="font-display font-700 text-xl text-white">
          Nominations
          <span class="ml-2 text-sm font-body font-normal text-slate-500">{{ cards | length }} submitted</span>
        </h2>
        {% if season and not seasonActive %}
          <span class="text-xs text-slate-600 italic">Final results</span>
        {% endif %}
      </div>

      {% if not season %}
        <div class="text-center py-24 text-slate-700">
          <svg class="w-10 h-10 mx-auto mb-4 opacity-40" fill="none" stroke="currentColor" stroke-width="1" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          <p class="font-display font-semibold text-lg mb-1">Waiting for the first season</p>
          <p class="text-sm">Check back soon.</p>
        </div>
      {% elif cards | length == 0 %}
        <div class="text-center py-24 text-slate-600">
          <svg class="w-12 h-12 mx-auto mb-4 opacity-40" fill="none" stroke="currentColor" stroke-width="1" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15.182 15.182a4.5 4.5 0 01-6.364 0M21 12a9 9 0 11-18 0 9 9 0 0118 0zM9.75 9.75c0 .414-.168.75-.375.75S9 10.164 9 9.75 9.168 9 9.375 9s.375.336.375.75zm-.375 0h.008v.015h-.008V9.75zm5.625 0c0 .414-.168.75-.375.75s-.375-.336-.375-.75.168-.75.375-.75.375.336.375.75zm-.375 0h.008v.015h-.008V9.75z"/></svg>
          <p class="font-display font-semibold text-lg mb-1">No nominations yet</p>
          <p class="text-sm">Be the first to suggest a character!</p>
        </div>
      {% else %}
        <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-4">
          {% for card in cards %}
          <div class="card-enter group bg-obsidian-800 border border-white/8 rounded-2xl overflow-hidden hover:border-indigo-500/30 hover:shadow-xl hover:shadow-indigo-900/20 transition-all duration-200"
            style="animation-delay: {{ loop.index0 * 40 }}ms">

            <!-- Image -->
            <div class="relative overflow-hidden bg-obsidian-700">
              <img src="/char_voting/uploads/{{ card.image_filename }}" alt="{{ card.char_name }}"
                class="card-image w-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
              <div class="absolute bottom-0 left-0 right-0 bg-gradient-to-t from-obsidian-900/90 to-transparent px-2.5 pt-8 pb-2.5">
                <span class="text-xs text-indigo-300 font-medium truncate block">{{ card.game_name }}</span>
              </div>
            </div>

            <!-- Info -->
            <div class="px-3 pt-2.5 pb-1">
              <h3 class="font-display font-700 text-sm text-white truncate leading-tight">{{ card.char_name }}</h3>
              <p class="text-xs text-slate-500 mt-0.5 truncate">by {{ card.username }}</p>
              {% if card.status == 'approved' %}
              <p class="text-[10px] font-semibold text-violet-400 mt-1 uppercase tracking-wide">On blocklist</p>
              {% endif %}
            </div>

            <!-- Admin actions -->
            {% if isAdmin %}
            <div class="px-3 pb-1 flex flex-col gap-1">
              {% if season and season.status == 'complete' and card.status != 'approved' %}
              <button type="button"
                class="w-full flex items-center justify-center gap-1 py-1 rounded-lg text-xs font-medium text-violet-300 border border-violet-500/25 hover:bg-violet-500/10 transition-all"
                data-id="{{ card.id }}"
                onclick="approveSubmission(this)">
                Approve
              </button>
              {% endif %}
              <button
                class="w-full flex items-center justify-center gap-1 py-1 rounded-lg text-xs font-medium text-slate-600 border border-white/5 hover:bg-rose-500/10 hover:text-rose-400 hover:border-rose-500/25 transition-all"
                data-id="{{ card.id }}"
                onclick="deleteEntry(this)">
                <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M14.74 9l-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 01-2.244 2.077H8.084a2.25 2.25 0 01-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 00-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 013.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 00-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 00-7.5 0"/></svg>
                Remove
              </button>
            </div>
            {% endif %}

            <!-- Vote row -->
            <div class="px-3 pb-3 pt-1 flex gap-2">
              <button
                class="vote-btn flex-1 flex items-center justify-center gap-1 py-1.5 rounded-lg text-xs font-semibold transition-all
                  {% if card.user_vote == 'up' %}bg-emerald-500/20 text-emerald-400 border border-emerald-500/40
                  {% else %}bg-white/5 text-slate-400 border border-white/8 hover:bg-emerald-500/10 hover:text-emerald-400 hover:border-emerald-500/30{% endif %}"
                data-id="{{ card.id }}" data-type="up"
                {% if not seasonActive or card.status == 'approved' %}disabled title="{% if card.status == 'approved' %}Approved / blocklisted{% else %}Voting is closed{% endif %}"{% endif %}
                onclick="castVote(this)">
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 10.5l7.5-7.5 7.5 7.5M12 3v18"/></svg>
                <span class="up-count">{{ card.up_votes }}</span>
              </button>
              <button
                class="vote-btn flex-1 flex items-center justify-center gap-1 py-1.5 rounded-lg text-xs font-semibold transition-all
                  {% if card.user_vote == 'down' %}bg-rose-500/20 text-rose-400 border border-rose-500/40
                  {% else %}bg-white/5 text-slate-400 border border-white/8 hover:bg-rose-500/10 hover:text-rose-400 hover:border-rose-500/30{% endif %}"
                data-id="{{ card.id }}" data-type="down"
                {% if not seasonActive or card.status == 'approved' %}disabled title="{% if card.status == 'approved' %}Approved / blocklisted{% else %}Voting is closed{% endif %}"{% endif %}
                onclick="castVote(this)">
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 13.5L12 21l-7.5-7.5M12 21V3"/></svg>
                <span class="down-count">{{ card.down_votes }}</span>
              </button>
            </div>
          </div>
          {% endfor %}
        </div>
      {% endif %}
    </div>
  </main>

  <script>
    const IS_LOGGED_IN  = {{ 'true' if user else 'false' }};
    const IS_ADMIN      = {{ 'true' if isAdmin else 'false' }};
    const SEASON_ACTIVE = {{ 'true' if seasonActive else 'false' }};
    const CONTEXT_SEASON_ID = {{ season.id if season else 'null' }};

    // ── Submit panel toggle ──────────────────────────────────
    const toggleBtn   = document.getElementById('toggleSubmit');
    const submitPanel = document.getElementById('submitPanel');
    const toggleIcon  = document.getElementById('toggleIcon');
    const toggleLabel = document.getElementById('toggleLabel');
    let panelOpen = false;

    if (toggleBtn) {
      toggleBtn.addEventListener('click', () => {
        panelOpen = !panelOpen;
        submitPanel.classList.toggle('collapsed', !panelOpen);
        submitPanel.classList.toggle('expanded', panelOpen);
        toggleIcon.style.transform = panelOpen ? 'rotate(45deg)' : '';
        toggleLabel.textContent = panelOpen ? 'Cancel' : 'Submit a Character';
      });
    }

    // ── Image drop zone ──────────────────────────────────────
    const dropZone        = document.getElementById('dropZone');
    const imageInput      = document.getElementById('imageInput');
    const imagePreview    = document.getElementById('imagePreview');
    const dropPlaceholder = document.getElementById('dropPlaceholder');

    if (dropZone) {
      dropZone.addEventListener('click', () => imageInput.click());
      dropZone.addEventListener('dragover', (e) => { e.preventDefault(); dropZone.classList.add('dragging'); });
      dropZone.addEventListener('dragleave', () => dropZone.classList.remove('dragging'));
      dropZone.addEventListener('drop', (e) => {
        e.preventDefault();
        dropZone.classList.remove('dragging');
        const file = e.dataTransfer.files[0];
        if (file) showPreview(file);
      });
      imageInput.addEventListener('change', () => {
        if (imageInput.files[0]) showPreview(imageInput.files[0]);
      });
    }

    function showPreview(file) {
      const reader = new FileReader();
      reader.onload = (e) => {
        imagePreview.src = e.target.result;
        imagePreview.classList.remove('hidden');
        dropPlaceholder.classList.add('hidden');
      };
      reader.readAsDataURL(file);
    }

    // ── Submit form ──────────────────────────────────────────
    const submitForm  = document.getElementById('submitForm');
    const submitBtn   = document.getElementById('submitBtn');
    const submitError = document.getElementById('submitError');

    if (submitForm) {
      submitForm.addEventListener('submit', async (e) => {
        e.preventDefault();
        submitBtn.disabled = true;
        submitBtn.textContent = 'Submitting…';
        submitError.classList.add('hidden');

        try {
          const res  = await fetch('/char_voting/submit', { method: 'POST', body: new FormData(submitForm) });
          const data = await res.json();
          if (!res.ok) {
            submitError.textContent = data.error || 'An error occurred.';
            submitError.classList.remove('hidden');
            return;
          }
          window.location.reload();
        } catch {
          submitError.textContent = 'Network error. Please try again.';
          submitError.classList.remove('hidden');
        } finally {
          submitBtn.disabled = false;
          submitBtn.textContent = 'Submit Character';
        }
      });
    }

    // ── Admin delete ─────────────────────────────────────────
    async function deleteEntry(btn) {
      const id = btn.dataset.id;
      if (!confirm('Remove this submission? This cannot be undone.')) return;
      btn.disabled = true;
      try {
        const res = await fetch(`/char_voting/delete/${id}`, { method: 'POST' });
        if (!res.ok) { btn.disabled = false; return; }
        const card = btn.closest('.card-enter');
        if (card) {
          card.style.transition = 'opacity 0.25s, transform 0.25s';
          card.style.opacity = '0';
          card.style.transform = 'scale(0.95)';
          setTimeout(() => card.remove(), 260);
        }
      } catch (e) {
        console.error(e);
        btn.disabled = false;
      }
    }

    // ── Admin season controls ────────────────────────────────
    let newSeasonOpen = false;
    function toggleNewSeason() {
      newSeasonOpen = !newSeasonOpen;
      const panel = document.getElementById('newSeasonPanel');
      panel.classList.toggle('collapsed', !newSeasonOpen);
      panel.classList.toggle('expanded', newSeasonOpen);
      if (newSeasonOpen) document.getElementById('newSeasonName').focus();
    }

    async function startSeason() {
      const name = document.getElementById('newSeasonName').value.trim();
      const errEl = document.getElementById('seasonAdminError');
      errEl.classList.add('hidden');
      if (!name) { errEl.textContent = 'Please enter a season name.'; errEl.classList.remove('hidden'); return; }

      try {
        const res  = await fetch('/char_voting/season/start', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ name }),
        });
        const data = await res.json();
        if (!res.ok) { errEl.textContent = data.error || 'Error starting season.'; errEl.classList.remove('hidden'); return; }
        window.location.reload();
      } catch {
        errEl.textContent = 'Network error.';
        errEl.classList.remove('hidden');
      }
    }

    async function closeSeason() {
      if (!confirm('Close the current season? Voting and submissions will be locked until a new season starts.')) return;
      try {
        const res = await fetch('/char_voting/season/close', { method: 'POST' });
        if (res.ok) window.location.reload();
      } catch (e) { console.error(e); }
    }

    async function markSeasonComplete() {
      if (!CONTEXT_SEASON_ID) return;
      if (!confirm('Mark this season complete? You can then approve nominations to add them to the blocklist.')) return;
      try {
        const res = await fetch('/char_voting/season/complete', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ season_id: CONTEXT_SEASON_ID }),
        });
        const data = await res.json().catch(() => ({}));
        if (!res.ok) {
          alert(data.error || 'Could not mark season complete.');
          return;
        }
        const q = new URLSearchParams(window.location.search);
        const seasonParam = q.get('season');
        window.location.href = seasonParam ? `/char_voting?season=${seasonParam}` : '/char_voting';
      } catch (e) {
        console.error(e);
        alert('Network error.');
      }
    }

    async function approveSubmission(btn) {
      const id = btn.dataset.id;
      if (!CONTEXT_SEASON_ID) return;
      btn.disabled = true;
      try {
        const res = await fetch(`/char_voting/approve/${id}`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ season_id: CONTEXT_SEASON_ID }),
        });
        const data = await res.json().catch(() => ({}));
        if (!res.ok) {
          alert(data.error || 'Could not approve.');
          btn.disabled = false;
          return;
        }
        window.location.reload();
      } catch (e) {
        console.error(e);
        btn.disabled = false;
        alert('Network error.');
      }
    }

    // Enter key on season name input
    const seasonNameInput = document.getElementById('newSeasonName');
    if (seasonNameInput) {
      seasonNameInput.addEventListener('keydown', (e) => { if (e.key === 'Enter') startSeason(); });
    }

    // ── Voting ───────────────────────────────────────────────
    async function castVote(btn) {
      if (!IS_LOGGED_IN) { window.location.href = '/auth/login'; return; }
      if (!SEASON_ACTIVE) return;

      const id       = btn.dataset.id;
      const voteType = btn.dataset.type;
      const allBtns  = btn.parentElement.querySelectorAll('.vote-btn');

      allBtns.forEach(b => b.disabled = true);

      try {
        const res = await fetch(`/char_voting/vote/${id}`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ vote_type: voteType }),
        });

        if (!res.ok) {
          if (res.status === 401) { window.location.href = '/auth/login'; return; }
          return;
        }

        const { up_votes, down_votes, user_vote } = await res.json();

        allBtns.forEach(b => {
          const active = b.dataset.type === user_vote;
          const isUp   = b.dataset.type === 'up';

          // Strip all colour classes then re-apply
          b.className = b.className
            .replace(/\b(bg|text|border)-(emerald|rose)-\S+/g, '')
            .replace(/\bhover:(bg|text|border)-(emerald|rose)-\S+/g, '')
            .trim();

          if (active && isUp) {
            b.classList.add('bg-emerald-500/20', 'text-emerald-400', 'border-emerald-500/40');
          } else if (active && !isUp) {
            b.classList.add('bg-rose-500/20', 'text-rose-400', 'border-rose-500/40');
          } else if (isUp) {
            b.classList.add('bg-white/5', 'text-slate-400', 'border-white/8',
              'hover:bg-emerald-500/10', 'hover:text-emerald-400', 'hover:border-emerald-500/30');
          } else {
            b.classList.add('bg-white/5', 'text-slate-400', 'border-white/8',
              'hover:bg-rose-500/10', 'hover:text-rose-400', 'hover:border-rose-500/30');
          }

          b.querySelector('.up-count, .down-count').textContent =
            b.dataset.type === 'up' ? up_votes : down_votes;
        });
      } catch (err) {
        console.error('Vote error', err);
      } finally {
        allBtns.forEach(b => b.disabled = false);
      }
    }
  </script>
</body>
</html>
